body {
	background-color: #f5f5f5;
}
.container {
	width: 1070px;
	margin: 0 auto;
}  
/* clearfix清除浮动 */
.clearfix:after {
	content: '';
	display: block;
	clear: both;
}
header .info {
	height: 32px;
	background-color: #f4f4f4;
	border-bottom: 1px solid #e5e5e5;
}
.info .container {
	height: 32px;
	padding-left: 10px;
	font-size: 12px;
	line-height: 32px;
}
header .icon-address {
	float: left;
}
header .login-info {
	float: right;
}
.login-info .text {
	margin-right: 15px;
}
.login-info .login {
	color: red;
}
.login-info .register {
	color: #aaa;
}
header .icon-address:hover ,header .text:hover ,.login-info .register:hover {
	color: red;
}
header .nav {
	background-color: #fff;
}
.nav .container {
	position: relative;
	height: 180px;	
}
.nav .logo-left {
	float: left;
	width: 300px;
	height: 140px;
	font-size: 0;
}
.nav .search-right {
	float: right;
	width: 650px;
	height: 67px;
	padding-top: 50px;
}
.nav input[type="text"] {
	width: 490px;
	height: 42px;
	padding-left: 22px;
	background-color: #FCFCFC;
	border: 1px solid #e5e5e5;
	border-radius: 40px;
}
.nav input[type="text"]:hover {
	background-color: #fff;
	border: 1px solid #ff4040;
}
.nav .cart {/* cart购物车 */
	float: right;
	width: 122px;
	height: 40px;
	border: 1px solid #e5e5e5;
	border-radius: 40px;
    text-align: center;
    line-height: 40px;
}
.nav .cart:hover {/* cart购物车 */
	background-color: #fcfcfc;
}
.nav .search-wrap {
	padding: 8px 0 0 32px;
}
.nav .search-list {
	margin-right: 10px;
	color: #aaa;
	font-size: 14px;
}
.nav .search-list:hover {
	color: #000;
}
.nav .top-nav {
	position: absolute;
	left: 0;
	bottom: 0;
	width: 1070px;
}
.top-nav .list-wrap ,.top-nav .item {
	float: left;
	height: 38px;
	line-height: 38px;
}
.top-nav .list-wrap {
	width: 140px;
	background-color: #ff4040;
	color: #fff;
	text-align: center;
}
.top-nav .item {
	margin-left: 30px;
	cursor: pointer;
}
.top-nav .item:hover {
	color: #ff4040;
}
header .ban-wrap {
	position: relative;
	height: 400px;
}
header .ban-list {
	display: none;
	position: absolute;
	width: 100%;
}
.ban-list .item{
	display: block;
	height: 400px;
}
header .ban-list:nth-child(1)>.item {
	background: url("../images/34dea747d569caf6.jpg") no-repeat center/cover;
}
header .ban-list:nth-child(2)>.item {
	background: url("../images/26f8012e4a3edba7.jpg") no-repeat center/cover;
}
header .ban-list:nth-child(3)>.item {
	background: url("../images/cdc1b9db8bdc62ec.jpg") no-repeat center/cover;
}
header .ban-list:nth-child(4)>.item {
	background: url("../images/ae8822c06b6bc3bd.jpg") no-repeat center/cover;
}
header .tab-btn {
	position: relative;
    top: -30px;
}
.tab-btn .tab-wrap {
	font-size: 0;
	text-align: center;
}
.tab-btn .tab-list {
	display: inline-block;
	width: 110px;
	height: 40px;
	margin-right: 10px;
	background-color: #fff;
	font-size: 14px;
	line-height: 40px;
	cursor: pointer;
}
.tab-btn .tab-list:hover {
	background-color: #000;
	color: #fff;
}
#content-page {
	position: relative;
	background-color: #f5f5f5;
}
#content-page .content-wrap {
	height: 370px;
	margin-top: 20px;
	background: url("../images/super_single_bg.png") no-repeat center/cover;
}
.content-wrap .product-wrap {
	width: 1050px;
	height: 422px;
	margin: 0 auto;
	padding-top: 10px;
}
.product-wrap .pro-list ,.single-one {
	float: left;
	width: 210px;
	height: 216px;
}
.product-wrap .pro-list {
	background-color: #fff;
	text-align: center;
}
.product-wrap .pro-list:hover {
	box-shadow: 0 5px 31px 0 rgba(0,0,0,0.09);
	transform: scale(1.06);
}
.product-wrap .pro-list:hover .hyperlink .single_title {
	color: red;
}
.single-one img {
	margin-left: 20px;
	margin-top: 22px;
}
.single-one .sing-text {
	margin-left: 24px;
}
.sing-text p {
	margin-right: 8px;
	color: #fcd8d9;
	font-size: 14px;
	font-weight: bold;
}
.sing-text .text-line {
	display: block;
	width: 28px;
	height: 1px;
	margin-top: 10px;
	margin-bottom: 17px;
	border-bottom: 3px solid #fff;
}
.sing-text .time-title {
	margin-top: 10px;
}
.time-title .text {
	display: block;
	height: 26px;
	margin-bottom: 9px;
	color: #fff;
	font-size: 16px;
	line-height: 26px;
}
.count-time .clock-time {
	display: inline-block;
	width: 35px;
	height: 35px;
	background-color: #161616;
	color: #fff;
	font-size: 20px;
	font-weight: bold;
	text-align: center;
	line-height: 35px;
	border-radius: 10px;
}
.pro-list .hyperlink {
	display: block;
	height: 216px;
	padding-top: 15px;
}
.hyperlink .single_bottom {
	width: 150px;
	height: 81px;
	margin: 0 auto;
	padding-top: 10px;
}
.hyperlink .single_title {
	width: 153px;
	height: 20px;
	font-size: 14px;
	white-space: nowrap;
	text-overflow: ellipsis;
	overflow: hidden;
}
.hyperlink .single_bar {
	height: 6px;
	margin-top: 10px;
	background-color: #e2e2e2;/* e2e2e2 */
	border-radius: 100px;
}
.hyperlink .single_pro {
	width: 38%;
	height: 100%;
	background-color: #d9161d;
	border-radius: 100px;
}
.hyperlink .single_price, .single_underline {
	padding-top: 12px;
	font-size: 0;
	color: #e50113;
}
.single_underline {
	margin-left: 5px;
	color: #999;
	text-decoration: line-through;/* 类似删除线 */
}
.hyperlink .single_unit, .single_num, .single_num, .single_line {
	font-size: 16px;
}
#content-page .download-app {
	position: absolute; 
	top: 157px; 
	right: 40px; 
	width: 100px;
}
#content-page .second-code {
	background-color: #fff;
	text-align: center;
}
.second-code .text {
	height: 30px;
	font-size: 14px;
	line-height: 30px;
}
#content-page .cart {
	display: block;
	height: 40px;
	background-color: #fff;
	border-top: 1px solid #f0f0f0;
	text-align: center;
	line-height: 40px;
}
/*类目列表css*/
#import_quality {
	margin-top: 95px;
}
#import_quality .container {
	margin-bottom: 22px;
	background-color: #fff;
}
#import_quality .show_left,#import_quality .show_right {
	float: left;
	width: 899px;
	height: 421px;
}
#import_quality .title_link {
	display: block;
	height: 67px;
}
#import_quality .title_link span:first-child {
	display: inline-block;
	margin-top: 17px;
	margin-left: 20px;
	font-size: 26px;
	color: #b77347;
}
#import_quality .part2 .title_link span:first-child {
	color: #A8E48E;
}
#import_quality .part3 .title_link span:first-child {
	color: #E453AA;
}
#import_quality .part4 .title_link span:first-child {
	color: #BDCAF6;
}
#import_quality .title_link span:last-child {
	display: inline-block;
	margin-top: 27px;
	margin-left: 8px;
	color: #CC9D7E;
}
#import_quality .part2 .title_link span:last-child {
	color: #A8E48E;
}
#import_quality .part3 .title_link span:last-child {
	color: #EC85C2;
}
#import_quality .part4 .title_link span:last-child {
	color: #92A1DB;
}
#import_quality .show_list {
	position: relative;
	width: 880px;
	padding-left: 20px;
}
#import_quality .show_list .show_pic {
	float: left;
}
#import_quality .show_list .left_list {
	position: absolute;
	top: 16px;
	width: 176px;
	margin-left: 14px;
}
#import_quality .left_list a {
	float: left;
	width: 74px;
	margin-right: 9px;
	margin-bottom: 9px;
	background-color: #E9C0A4;
	border: 1px solid #fff;
	color: #fff;
	font-size: 14px;
	text-align: center;
	line-height: 23px;
}
#import_quality .part2 .left_list a {
	background-color: #B7E99E;
}
#import_quality .part3 .left_list a {
	background-color: #F5B9E0;
}
#import_quality .part4 .left_list a {
	background-color: #C0CCF4;
}
#import_quality .show_list .right_list {
	float: left;
	width: 680px;
	height: 334px;
}
#import_quality .right_list a {
	float: left;
}
#import_quality .right_list a:nth-child(1),#import_quality .right_list a:nth-child(6) {
	width: 335px;
	height: 167px;
	background-color: #faf7f6;
}
#import_quality .part1 .right_list a {	
	color: #793A11;
}
#import_quality .right_list a:nth-child(2),#import_quality .right_list a:nth-child(3) {
	width: 168px;
	height: 167px;
	background-color: #fff;
}
#import_quality .part2 .right_list a {	
	color: #3c8020;
}
#import_quality .part3 .right_list a {	
	color: #F499D2;
}
#import_quality .right_list a:nth-child(4),#import_quality .right_list a:nth-child(5) {
	width: 168px;
	height: 167px;
	background-color: #fff;
}
#import_quality .part4 .right_list a {	
	color: #1e389a ;
}
#import_quality .right_list a:nth-child(6) {
	background-color: #FAF8F7;
}
#import_quality .right_list .pro_title,#import_quality .right_list .pro_desc {
	margin-left: 30px;
	width: 150px;
	font-size: 14px;
}
#import_quality .right_list .pro_title_single,#import_quality .right_list .pro_desc_single {
	margin-left: 15px;
	width: 150px;
	font-size: 14px;
}
#import_quality .right_list .pro_title {
	margin-top: 40px;
}
#import_quality .right_list .pro_title_single {
	margin-top: 15px;
	color: #793a11;
}
#import_quality .part1 .right_list .pro_desc {
	margin-top: 5px;
	color: #b77347;
}
#import_quality .part2 .right_list .pro_desc {
	margin-top: 5px;
	color: #69b14b ;
}
#import_quality .part3 .right_list .pro_desc {
	margin-top: 5px;
	color: #A858A0;
}
#import_quality .part4 .right_list .pro_desc {
	margin-top: 5px;
	color: #1E38B3;
}
#import_quality .right_list .pro_desc_single {
	margin-top: 5px;
	color: #999;
}
#import_quality .right_list .buy_btn {
	margin-top: 15px;
	margin-left: 30px;
	width: 78px;
	height: 27px;
	border: 1px solid #EFC697;
	color: #e49337;
	font-size: 14px;
	text-align: center;
	line-height: 27px;
}
#import_quality .part2 .right_list .buy_btn {
	border: 1px solid #b1e897;
	color: #72BF25;
}
#import_quality .part3 .right_list .buy_btn {
	border: 1px solid #E6A7CC;
	color: #D15AA0;
}
#import_quality .part4 .right_list .buy_btn {
	border: 1px solid #BBC8F4;
	color: #647EDC;
}
#import_quality .right_list .buy_btn:hover {
	background-color: #fff;
}
#import_quality .right_list .pro_pic,#import_quality .right_list .pic_right_bottom {
	float: right;
	transition: .5s;
}
#import_quality .right_list .pro_pic {
	margin-right: 30px;
	margin-top: -100px;
}
#import_quality .right_list .pic_right_bottom {
	margin-right: 10px;
	margin-bottom: 30px;
}
#import_quality .right_list .pro_pic:hover {
	transform: translate3d(-5px,0,0);/*x,y,z*/
	/* transform: translateX(-5px); */
}
#import_quality .right_list .pic_right_bottom:hover {
	transform: translate3d(-5px,0,0);/*x,y,z*/
	/* transform: translateX(-5px); */
}
#import_quality .show_right {
	position: relative;
	width: 170px;
	border-left: 1px solid #f6f6f6;
}
#import_quality .rank_list {
	position: absolute;
	left: 81px;
}
#import_quality .top_font {
	margin: 20px 0 7px 20px;
}
#import_quality .font_descript {
	margin-left: 20px;
	font-size: 14px;
	color: #b0b0b0;
}
#import_quality .rank_item {
	position: absolute;
	left: 28px;
	bottom: 39px;
	width: 120px;
	height: 317px;
	overflow: hidden;
}
#import_quality .rank_item li {
	position: relative;
	top: 10px;
	left: 10px;
	width: 90px;
	height: 90px;
	margin-bottom: 11px;
	background-color: #fff;
	box-shadow: 0 2px 20px rgba(0,0,0,.07);
	cursor: pointer;
}
#import_quality .rank_item .img_font {
	position: absolute;
	width: 40px;
	height: 16px;
	font-size: 12px;
	color: #fff;
	text-align: center;
	font-weight: bold;
}
#import_quality .rank_item li:nth-child(1)>.img_font {
	background: url("../images/top1.png") no-repeat center/cover;
}
#import_quality .rank_item li:nth-child(2)>.img_font {
	background: url("../images/top2.png") no-repeat center/cover;
}
#import_quality .rank_item li:nth-child(3)>.img_font {
	background: url("../images/top3.png") no-repeat center/cover;
}
#import_quality .rank_item img {
	position: absolute;
	bottom: 5px;
	left: 20px;
}
#import_quality .rank_btn {
	position: absolute;
	left: 60px;
	bottom: 20px;
	width: 16px;
	background-color: #ebebeb;
	line-height: 16px;
	cursor: pointer;
}
/*类目列表css*/
/*懂你想要css*/
#know_want .title {
	position: relative;
	height: 131px;
	text-align: center;
}
#know_want .title_font {
	position: absolute;
	top: 46%;
	left: 43%;
	color: #999;
}
#know_want .like_pro .pro_wait {
	height: 80px;
	margin-bottom: 15px;
	background: url("../images/loading-yhdUpdate_01.gif") no-repeat center;/*center center表示position的x,y */
}
#know_want .like_pro li {
	position: relative;
	float: left;
	width: 168px;
	height: 236px;
	margin: 0 10px 10px 0;
	background-color: #fff;
}
#know_want .like_pro li:hover .pro_title,#know_want .like_pro li:hover .pro_price {
	opacity: .1;
}
#know_want .like_pro li:hover .pro_hover,#know_want .like_pro li:hover .last_link {
	opacity: 1;
}
#know_want .like_pro .pro_pic,#know_want .like_pro .pro_title {
	width: 150px;
	margin: 10px 0 0 10px;
}
#know_want .like_pro .pro_title {
	display: -webkit-box;/*  css3盒模型*/
	-webkit-box-orient: vertical;/* 盒子方向  */
    -webkit-line-clamp: 2;/* 保留盒子几行?  */
	height: 38px;
	margin: 5px 0 0 10px;
	font-size: 14px;
	overflow: hidden;
	/* text-overflow: ellipsis; *//*  省略号 */
	line-height: 20px;
	/* word-break: break-all; *//* 允许在单词内换行。 */
}
#know_want .like_pro .pro_price {
	margin: 8px 0 0 8px;
	color: #ff4040;
	font-size: 0;
	font-weight: bold;
} 
#know_want .pro_price span {
	font-size: 14px;
}
#know_want .like_pro .pro_hover,#know_want .like_pro .last_link {
	position: absolute;
	left: 0;
	opacity: 0;
	transition: .5s;
}
#know_want .like_pro .pro_hover {
	bottom: 0;
	width: 170px;
	height: 74px;
}
#know_want .pro_hover .pro_left,#know_want .pro_hover .pro_right {
	position: absolute;
	top: 11px;
	left: 30px;
	width: 48px;
	height: 48px;
	background-color: #ff4040;
	border-radius: 24px;
	line-height: 48px;
}
#know_want .pro_hover .pro_right {
	left: 92px;
	background-color: #fff0f0;
	border: 1px solid #ffcdcd;
	color: #ff4040;
	font-size: 12px;
	line-height: 48px;
	text-align: center;
	box-sizing: border-box;/* 用来限定盒子大小  */
}
#know_want .like_pro .last_link {
	top: 0;
	width: 168px;
	height: 236px;
	outline: 1px solid #ff4040;
}
/*懂你想要css*/
/*copyright_css*/
#fb_copyrig {
	background-color: #fff;	
}
#fb_copyrig .fb_service {
	padding: 30px 0;
	border-bottom: 1px solid #ebebeb;
}
#fb_copyrig .fb_service a {
	float: left;
	width: 205px;
	margin-right: 81px;
	cursor: default;
}
#fb_copyrig .fb_service a:last-child {
	margin-right: 0;
}
#fb_copyrig .fb_service img {
	float: left;
	margin-right: 15px;
}
#fb_copyrig .fb_service b {
	display: block;
	margin-top: 10px;
	font-size: 16px;
}
#fb_copyrig .fb_service span {
	font-size: 14px;
	color: #999;
	line-height: 26px;
}
#fb_copyrig .service_link {
	padding: 20px 0;
	color: #666;
	font-size: 14px;
}
#fb_copyrig .service_left {
	float: left;
	padding-left: 15px;
}
#fb_copyrig .service_left dl {
	float: left;
	width: 195px;
}
#fb_copyrig .service_left dt {
	padding-bottom: 5px;
	font-weight: bold;
}
#fb_copyrig .service_left dd {
	height: 24px;
	font-size: 12px;
	line-height: 24px;
}
#fb_copyrig .service_right {
	float: left;
	width: 280px;
	margin-right: -50px;
}
#fb_copyrig .code_left,#fb_copyrig .code_right {
	float: left;
	margin-right: 50px;
}
#fb_copyrig .fb_info {
	font-size: 12px;
}
#fb_copyrig .fb_info a:first-child {
	margin-left: 7px;
}
#fb_copyrig .fb_info a:hover {
	color: #c00;
}
#fb_copyrig .fb_info span {
	margin: 0 3px;
}
#fb_copyrig .info_link+p {
	margin-top: 10px;
	color: #666;
	text-align: center;
}
#fb_copyrig .fb_info small {
	display: block;
	margin-top: 24px;
	padding-bottom: 22px;
	text-align: center;
}
/*copyright_css*/